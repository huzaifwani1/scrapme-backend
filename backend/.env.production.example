# Scrapme Production Environment Configuration
# Copy this file to .env.production and fill in your actual values

PORT=3001

# Environment
NODE_ENV=production

# MongoDB Atlas Production URI
# Replace with your actual MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/scrapme_production

# JWT Secrets - Generate strong random secrets for production
JWT_SECRET=your_strong_jwt_secret_minimum_32_chars_random
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=your_strong_admin_jwt_secret_different_from_above

# Admin Credentials - CHANGE THESE BEFORE DEPLOYMENT
ADMIN_USERNAME=admin_production
# Generate a new hashed password using: node -e "console.log(require('bcryptjs').hashSync('your_strong_password_here', 10))"
ADMIN_PASSWORD_HASH=$2a$10$your_new_hashed_password_here

# Email Configuration (Production)
# Use a real email service like SendGrid, Mailgun, or AWS SES
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=your_sendgrid_api_key_here
EMAIL_FROM=noreply@yourdomain.com
EMAIL_ENABLED=true

# Rate Limiting (Production - stricter)
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # 100 requests per window per IP

# Security
SESSION_SECRET=your_session_secret_here
COOKIE_SECURE=true  # Set to true for HTTPS
COOKIE_SAMESITE=strict

# Frontend URL for CORS
FRONTEND_URL=https://yourdomain.com